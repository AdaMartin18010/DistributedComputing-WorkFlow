@prefix dc: <http://purl.org/dc/elements/1.1/> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix : <http://distributedcomputing.org/ontology#> .
@prefix person: <http://distributedcomputing.org/person#> .
@prefix paper: <http://distributedcomputing.org/paper#> .
@prefix sys: <http://distributedcomputing.org/system#> .

# ============================================
# 核心定理与理论基础 (Theorems & Theory)
# ============================================

:CAPTheorem rdf:type :Theorem, owl:NamedIndividual ;
    rdfs:label "CAP定理"@zh, "CAP Theorem"@en ;
    :name "CAP定理"@zh ;
    :nameEn "CAP Theorem"@en ;
    :definition "在一个分布式计算系统中，一致性、可用性、分区容忍性三者不可兼得，最多只能同时满足其中两项"@zh ;
    :definitionEn "In a distributed computing system, it is impossible to simultaneously provide more than two out of the three guarantees: Consistency, Availability, and Partition Tolerance"@en ;
    :category :Theory ;
    :hasPart :Consistency, :Availability, :PartitionTolerance ;
    :relatedTo :PACELC, :TwoGeneralsProblem ;
    :hasYear 2000 ;
    :proposedBy person:EricBrewer ;
    :provedBy person:SethGilbert, person:NancyLynch ;
    :difficulty "中级"@zh .

:FLPResult rdf:type :Theorem, owl:NamedIndividual ;
    rdfs:label "FLP不可能性结果"@zh, "FLP Impossibility"@en ;
    :name "FLP不可能性结果"@zh ;
    :nameEn "FLP Impossibility"@en ;
    :definition "在异步系统中，即使只有一个进程可能崩溃，也不存在确定性的共识算法"@zh ;
    :category :Theory ;
    :hasYear 1985 ;
    :proposedBy person:MichaelFischer, person:NancyLynch, person:MichaelPaterson ;
    :relatedTo :CAPTheorem, :ConsensusProblem ;
    :difficulty "高级"@zh .

:TwoGeneralsProblem rdf:type :Theorem, owl:NamedIndividual ;
    rdfs:label "两将军问题"@zh, "Two Generals Problem"@en ;
    :name "两将军问题"@zh ;
    :nameEn "Two Generals Problem"@en ;
    :definition "两个将军需要通过不可靠的信使通信来协调攻击，证明了在不可靠通信信道上无法保证达成的共识"@zh ;
    :category :Theory ;
    :hasYear 1975 ;
    :relatedTo :ByzantineGeneralsProblem, :ConsensusProblem ;
    :difficulty "中级"@zh .

:ByzantineGeneralsProblem rdf:type :Theorem, owl:NamedIndividual ;
    rdfs:label "拜占庭将军问题"@zh, "Byzantine Generals Problem"@en ;
    :name "拜占庭将军问题"@zh ;
    :nameEn "Byzantine Generals Problem"@en ;
    :definition "描述在存在叛徒（拜占庭故障）的情况下，忠诚的将军如何达成共识的问题"@zh ;
    :category :Theory ;
    :hasYear 1982 ;
    :proposedBy person:LeslieLamport, person:RobertShostak, person:MarshallPease ;
    :solvedBy :PBFT ;
    :difficulty "高级"@zh .

:PACELC rdf:type :Theorem, owl:NamedIndividual ;
    rdfs:label "PACELC定理"@zh, "PACELC Theorem"@en ;
    :name "PACELC定理"@zh ;
    :nameEn "PACELC Theorem"@en ;
    :definition "扩展CAP定理，指出如果存在分区(P)，必须在可用性(A)和一致性(C)之间选择；否则(E)，必须在延迟(L)和一致性(C)之间选择"@zh ;
    :category :Theory ;
    :hasYear 2010 ;
    :proposedBy person:DanielAbadi ;
    :extends :CAPTheorem ;
    :difficulty "中级"@zh .

# ============================================
# 一致性模型 (Consistency Models)
# ============================================

:Consistency rdf:type :Concept, owl:NamedIndividual ;
    rdfs:label "一致性"@zh, "Consistency"@en ;
    :name "一致性"@zh ;
    :nameEn "Consistency"@en ;
    :definition "分布式系统中所有节点在同一时间看到相同数据的特性"@zh ;
    :category :Theory ;
    :hasPart :Linearizability, :SequentialConsistency, :CausalConsistency, :EventualConsistency ;
    :difficulty "初级"@zh .

:Linearizability rdf:type :Concept, owl:NamedIndividual ;
    rdfs:label "线性一致性"@zh, "Linearizability"@en ;
    :name "线性一致性"@zh ;
    :nameEn "Linearizability"@en ;
    :definition "最强的单对象一致性模型，要求操作看起来在调用的瞬间原子性地生效"@zh ;
    :category :Theory ;
    :isA :ConsistencyModel ;
    :implementedBy sys:ZooKeeper, sys:etcd, sys:Consul ;
    :difficulty "高级"@zh .

:SequentialConsistency rdf:type :Concept, owl:NamedIndividual ;
    rdfs:label "顺序一致性"@zh, "Sequential Consistency"@en ;
    :name "顺序一致性"@zh ;
    :nameEn "Sequential Consistency"@en ;
    :definition "所有进程看到的操作执行顺序一致，但不需要与实时顺序一致"@zh ;
    :category :Theory ;
    :isA :ConsistencyModel ;
    :difficulty "中级"@zh .

:CausalConsistency rdf:type :Concept, owl:NamedIndividual ;
    rdfs:label "因果一致性"@zh, "Causal Consistency"@en ;
    :name "因果一致性"@zh ;
    :nameEn "Causal Consistency"@en ;
    :definition "保证因果相关的操作被所有进程以相同顺序看到"@zh ;
    :category :Theory ;
    :isA :ConsistencyModel ;
    :implementedBy sys:COPS, sys:AntidoteDB ;
    :difficulty "中级"@zh .

:EventualConsistency rdf:type :Concept, owl:NamedIndividual ;
    rdfs:label "最终一致性"@zh, "Eventual Consistency"@en ;
    :name "最终一致性"@zh ;
    :nameEn "Eventual Consistency"@en ;
    :definition "如果没有新的更新，最终所有副本都会收敛到相同的值"@zh ;
    :category :Theory ;
    :isA :ConsistencyModel ;
    :implementedBy sys:DynamoDB, sys:Cassandra, sys:Riak ;
    :difficulty "初级"@zh .

:ConsistencyModel rdf:type :Concept, owl:NamedIndividual ;
    rdfs:label "一致性模型"@zh, "Consistency Model"@en ;
    :name "一致性模型"@zh ;
    :nameEn "Consistency Model"@en ;
    :definition "定义分布式系统中数据一致性的规则和保证"@zh ;
    :category :Theory ;
    :hasPart :Linearizability, :SequentialConsistency, :CausalConsistency, :EventualConsistency ;
    :difficulty "中级"@zh .

# ============================================
# 共识算法 (Consensus Algorithms)
# ============================================

:ConsensusProblem rdf:type :Concept, owl:NamedIndividual ;
    rdfs:label "共识问题"@zh, "Consensus Problem"@en ;
    :name "共识问题"@zh ;
    :nameEn "Consensus Problem"@en ;
    :definition "分布式系统中多个进程就某个值达成一致的协议问题"@zh ;
    :category :Theory ;
    :solvedBy :Paxos, :Raft, :PBFT, :ZAB ;
    :difficulty "中级"@zh .

:Paxos rdf:type :Algorithm, owl:NamedIndividual ;
    rdfs:label "Paxos算法"@zh, "Paxos Algorithm"@en ;
    :name "Paxos算法"@zh ;
    :nameEn "Paxos Algorithm"@en ;
    :definition "一种用于解决分布式系统中共识问题的经典算法"@zh ;
    :category :Algorithm ;
    :isA :ConsensusAlgorithm ;
    :complexity "O(n²) messages per consensus" ;
    :faultTolerance "Crash fault tolerance, minority failures"@en ;
    :hasPart :PreparePhase, :AcceptPhase, :LearnPhase ;
    :proposedBy person:LeslieLamport ;
    :hasYear 1989 ;
    :publishedIn paper:PaxosPaper ;
    :implementedBy sys:Chubby, sys:ZooKeeper ;
    :solves :ConsensusProblem ;
    :extendedBy :MultiPaxos, :FastPaxos, :EPaxos ;
    :difficulty "高级"@zh .

:Raft rdf:type :Algorithm, owl:NamedIndividual ;
    rdfs:label "Raft算法"@zh, "Raft Algorithm"@en ;
    :name "Raft算法"@zh ;
    :nameEn "Raft Algorithm"@en ;
    :definition "一种为管理复制日志而设计的易于理解的共识算法"@zh ;
    :category :Algorithm ;
    :isA :ConsensusAlgorithm ;
    :complexity "O(n) messages per consensus" ;
    :faultTolerance "Crash fault, minority partition"@en ;
    :hasPart :LeaderElection, :LogReplication, :Safety ;
    :proposedBy person:DiegoOngaro, person:JohnOusterhout ;
    :hasYear 2014 ;
    :publishedIn paper:RaftPaper ;
    :implementedBy sys:etcd, sys:Consul, sys:TiKV, sys:Nacos ;
    :solves :ConsensusProblem ;
    :improvesUpon :Paxos ;
    :uses :StrongLeadership, :LogReplication ;
    :difficulty "中级"@zh .

:MultiPaxos rdf:type :Algorithm, owl:NamedIndividual ;
    rdfs:label "Multi-Paxos算法"@zh, "Multi-Paxos Algorithm"@en ;
    :name "Multi-Paxos算法"@zh ;
    :nameEn "Multi-Paxos Algorithm"@en ;
    :definition "Paxos的优化版本，通过选举稳定的主节点减少消息轮数"@zh ;
    :category :Algorithm ;
    :isA :ConsensusAlgorithm ;
    :extends :Paxos ;
    :hasYear 2001 ;
    :implementedBy sys:Chubby, sys:Spanner ;
    :difficulty "高级"@zh .

:FastPaxos rdf:type :Algorithm, owl:NamedIndividual ;
    rdfs:label "Fast-Paxos算法"@zh, "Fast-Paxos Algorithm"@en ;
    :name "Fast-Paxos算法"@zh ;
    :nameEn "Fast-Paxos Algorithm"@en ;
    :definition "Paxos的变种，允许客户端直接向所有Acceptor发送请求以减少延迟"@zh ;
    :category :Algorithm ;
    :isA :ConsensusAlgorithm ;
    :extends :Paxos ;
    :hasYear 2006 ;
    :proposedBy person:LeslieLamport ;
    :difficulty "高级"@zh .

:EPaxos rdf:type :Algorithm, owl:NamedIndividual ;
    rdfs:label "EPaxos算法"@zh, "EPaxos Algorithm"@en ;
    :name "EPaxos算法"@zh ;
    :nameEn "EPaxos Algorithm"@en ;
    :definition "Egalitarian Paxos，无主节点的Paxos变种，支持并行提交"@zh ;
    :category :Algorithm ;
    :isA :ConsensusAlgorithm ;
    :extends :Paxos ;
    :hasYear 2013 ;
    :implementedBy sys:ScyllaDB ;
    :difficulty "高级"@zh .

:PBFT rdf:type :Algorithm, owl:NamedIndividual ;
    rdfs:label "PBFT算法"@zh, "PBFT Algorithm"@en ;
    :name "PBFT算法"@zh ;
    :nameEn "Practical Byzantine Fault Tolerance"@en ;
    :definition "实用的拜占庭容错算法，容忍不超过1/3的拜占庭故障节点"@zh ;
    :category :Algorithm ;
    :isA :ConsensusAlgorithm, :BFTAlgorithm ;
    :complexity "O(n²) messages per request" ;
    :faultTolerance "Byzantine fault, up to f < n/3"@en ;
    :hasPart :PrePrepare, :Prepare, :Commit ;
    :proposedBy person:MiguelCastro, person:BarbaraLiskov ;
    :hasYear 1999 ;
    :publishedIn paper:PBFTPaper ;
    :implementedBy sys:Tendermint, sys:HyperledgerFabric ;
    :solves :ByzantineGeneralsProblem ;
    :difficulty "高级"@zh .

:ZAB rdf:type :Algorithm, owl:NamedIndividual ;
    rdfs:label "ZAB协议"@zh, "ZAB Protocol"@en ;
    :name "ZAB协议"@zh ;
    :nameEn "ZooKeeper Atomic Broadcast"@en ;
    :definition "ZooKeeper使用的原子广播协议，保证消息的全序广播"@zh ;
    :category :Algorithm ;
    :isA :ConsensusAlgorithm, :AtomicBroadcast ;
    :hasPart :Discovery, :Synchronization, :Broadcast ;
    :implementedBy sys:ZooKeeper ;
    :difficulty "中级"@zh .

:ConsensusAlgorithm rdf:type :Concept, owl:NamedIndividual ;
    rdfs:label "共识算法"@zh, "Consensus Algorithm"@en ;
    :name "共识算法"@zh ;
    :nameEn "Consensus Algorithm"@en ;
    :definition "使分布式系统中多个节点就某个值达成一致的算法"@zh ;
    :category :Algorithm ;
    :hasSubtype :Paxos, :Raft, :PBFT, :ZAB, :ViewstampedReplication ;
    :difficulty "中级"@zh .

:BFTAlgorithm rdf:type :Concept, owl:NamedIndividual ;
    rdfs:label "拜占庭容错算法"@zh, "BFT Algorithm"@en ;
    :name "拜占庭容错算法"@zh ;
    :nameEn "Byzantine Fault Tolerant Algorithm"@en ;
    :definition "能够容忍拜占庭故障（恶意或任意行为）的共识算法"@zh ;
    :category :Algorithm ;
    :isA :ConsensusAlgorithm ;
    :hasPart :PBFT, :HotStuff, :Tendermint ;
    :difficulty "高级"@zh .

:ViewstampedReplication rdf:type :Algorithm, owl:NamedIndividual ;
    rdfs:label "Viewstamped Replication"@en ;
    :name "Viewstamped Replication"@en ;
    :definition "一种基于主备复制的共识算法，支持视图变更"@zh ;
    :category :Algorithm ;
    :isA :ConsensusAlgorithm ;
    :hasYear 1988 ;
    :hasYear 2012 ;
    :proposedBy person:BarbaraLiskov, person:JamesCowling ;
    :implementedBy sys:MongoDB ;
    :difficulty "中级"@zh .

# ============================================
# 选举与成员管理算法
# ============================================

:LeaderElection rdf:type :Concept, owl:NamedIndividual ;
    rdfs:label "领导者选举"@zh, "Leader Election"@en ;
    :name "领导者选举"@zh ;
    :nameEn "Leader Election"@en ;
    :definition "在分布式系统中选出一个协调者的过程"@zh ;
    :category :Algorithm ;
    :hasPart :BullyAlgorithm, :RingAlgorithm ;
    :implementedBy sys:ZooKeeper, sys:etcd ;
    :difficulty "中级"@zh .

:BullyAlgorithm rdf:type :Algorithm, owl:NamedIndividual ;
    rdfs:label "Bully算法"@zh, "Bully Algorithm"@en ;
    :name "Bully算法"@zh ;
    :nameEn "Bully Algorithm"@en ;
    :definition "基于进程ID的领导者选举算法，ID最大的进程成为领导者"@zh ;
    :category :Algorithm ;
    :isA :ElectionAlgorithm ;
    :hasYear 1982 ;
    :complexity "O(n²) messages" ;
    :difficulty "初级"@zh .

:RingAlgorithm rdf:type :Algorithm, owl:NamedIndividual ;
    rdfs:label "环算法"@zh, "Ring Algorithm"@en ;
    :name "环算法"@zh ;
    :nameEn "Ring Algorithm"@en ;
    :definition "基于逻辑环结构的领导者选举算法"@zh ;
    :category :Algorithm ;
    :isA :ElectionAlgorithm ;
    :complexity "O(n log n) messages" ;
    :difficulty "初级"@zh .

:MembershipProtocol rdf:type :Concept, owl:NamedIndividual ;
    rdfs:label "成员协议"@zh, "Membership Protocol"@en ;
    :name "成员协议"@zh ;
    :nameEn "Membership Protocol"@en ;
    :definition "管理分布式系统节点成员身份和故障检测的协议"@zh ;
    :category :Protocol ;
    :hasPart :SWIM, :GossipProtocol ;
    :difficulty "中级"@zh .

:SWIM rdf:type :Protocol, owl:NamedIndividual ;
    rdfs:label "SWIM协议"@zh, "SWIM Protocol"@en ;
    :name "SWIM协议"@zh ;
    :nameEn "Scalable Weakly-consistent Infection-style Process Group Membership"@en ;
    :definition "可扩展的弱一致性组成员协议，使用 gossip 方式进行故障检测"@zh ;
    :category :Protocol ;
    :hasYear 2002 ;
    :implementedBy sys:Consul, sys:Serf ;
    :difficulty "中级"@zh .

:GossipProtocol rdf:type :Protocol, owl:NamedIndividual ;
    rdfs:label "Gossip协议"@zh, "Gossip Protocol"@en ;
    :name "Gossip协议"@zh ;
    :nameEn "Gossip Protocol"@en ;
    :definition "基于随机传播的 epidemic 算法，用于信息传播和故障检测"@zh ;
    :category :Protocol ;
    :hasPart :AntiEntropy, :RumorMongering ;
    :implementedBy sys:Cassandra, sys:Consul, sys:Redis ;
    :difficulty "中级"@zh .

# ============================================
# 核心分布式系统 (Core Systems)
# ============================================

sys:etcd rdf:type :System, owl:NamedIndividual ;
    rdfs:label "etcd"@en ;
    :name "etcd"@en ;
    :nameEn "etcd"@en ;
    :definition "一个分布式键值存储，用于配置管理和服务发现"@zh ;
    :systemType :KeyValueStore, :ConfigurationStore ;
    :programmingLanguage "Go" ;
    :license "Apache-2.0" ;
    :github "https://github.com/etcd-io/etcd" ;
    :documentation "https://etcd.io/docs" ;
    :created 2013 ;
    :isActive true ;
    :implements :Raft ;
    :uses :gRPC, :BoltDB ;
    :usedBy sys:Kubernetes ;
    :relatedTo sys:ZooKeeper, sys:Consul ;
    :difficulty "中级"@zh .

sys:ZooKeeper rdf:type :System, owl:NamedIndividual ;
    rdfs:label "Apache ZooKeeper"@en ;
    :name "Apache ZooKeeper"@en ;
    :nameEn "Apache ZooKeeper"@en ;
    :definition "Apache Hadoop的子项目，提供分布式协调服务"@zh ;
    :systemType :CoordinationService, :ConfigurationStore ;
    :programmingLanguage "Java" ;
    :license "Apache-2.0" ;
    :github "https://github.com/apache/zookeeper" ;
    :created 2008 ;
    :isActive true ;
    :implements :ZAB, :MultiPaxos ;
    :uses :Jute ;
    :usedBy sys:Kafka, sys:HBase, sys:Hadoop ;
    :difficulty "中级"@zh .

sys:Consul rdf:type :System, owl:NamedIndividual ;
    rdfs:label "HashiCorp Consul"@en ;
    :name "HashiCorp Consul"@en ;
    :nameEn "HashiCorp Consul"@en ;
    :definition "服务发现、服务网格和配置管理的工具"@zh ;
    :systemType :ServiceDiscovery, :ServiceMesh ;
    :programmingLanguage "Go" ;
    :license "MPL-2.0" ;
    :github "https://github.com/hashicorp/consul" ;
    :created 2014 ;
    :isActive true ;
    :implements :Raft ;
    :uses :SWIM, :gossipProtocol ;
    :relatedTo sys:etcd, sys:ZooKeeper ;
    :difficulty "中级"@zh .

sys:Kafka rdf:type :System, owl:NamedIndividual ;
    rdfs:label "Apache Kafka"@en ;
    :name "Apache Kafka"@en ;
    :nameEn "Apache Kafka"@en ;
    :definition "高吞吐量的分布式消息流平台"@zh ;
    :systemType :MessageQueue, :StreamPlatform ;
    :programmingLanguage "Java, Scala" ;
    :license "Apache-2.0" ;
    :github "https://github.com/apache/kafka" ;
    :created 2011 ;
    :isActive true ;
    :uses :ZooKeeper, :Raft ;
    :relatedTo sys:RabbitMQ, sys:RocketMQ, sys:Pulsar ;
    :difficulty "中级"@zh .

sys:Redis rdf:type :System, owl:NamedIndividual ;
    rdfs:label "Redis"@en ;
    :name "Redis"@en ;
    :nameEn "Redis"@en ;
    :definition "内存数据结构存储，用作数据库、缓存和消息代理"@zh ;
    :systemType :Cache, :KeyValueStore, :MessageQueue ;
    :programmingLanguage "C" ;
    :license "BSD-3-Clause" ;
    :github "https://github.com/redis/redis" ;
    :created 2009 ;
    :isActive true ;
    :uses :GossipProtocol, :Raft ;
    :hasPart :RedisCluster, :RedisSentinel ;
    :difficulty "初级"@zh .

sys:Cassandra rdf:type :System, owl:NamedIndividual ;
    rdfs:label "Apache Cassandra"@en ;
    :name "Apache Cassandra"@en ;
    :nameEn "Apache Cassandra"@en ;
    :definition "分布式宽列存储，具有最终一致性和高可用性"@zh ;
    :systemType :WideColumnStore, :Database ;
    :programmingLanguage "Java" ;
    :license "Apache-2.0" ;
    :github "https://github.com/apache/cassandra" ;
    :created 2008 ;
    :isActive true ;
    :implements :GossipProtocol, :EventualConsistency ;
    :uses :LogStructuredMergeTree ;
    :relatedTo sys:ScyllaDB, sys:HBase, sys:BigTable ;
    :difficulty "中级"@zh .

sys:MongoDB rdf:type :System, owl:NamedIndividual ;
    rdfs:label "MongoDB"@en ;
    :name "MongoDB"@en ;
    :nameEn "MongoDB"@en ;
    :definition "面向文档的NoSQL数据库，支持复制和分片"@zh ;
    :systemType :DocumentStore, :Database ;
    :programmingLanguage "C++" ;
    :license "SSPL" ;
    :github "https://github.com/mongodb/mongo" ;
    :created 2009 ;
    :isActive true ;
    :implements :Raft ;
    :relatedTo sys:Couchbase, sys:DocumentDB ;
    :difficulty "初级"@zh .

sys:TiDB rdf:type :System, owl:NamedIndividual ;
    rdfs:label "TiDB"@en ;
    :name "TiDB"@en ;
    :nameEn "TiDB"@en ;
    :definition "开源的分布式NewSQL数据库，兼容MySQL协议"@zh ;
    :systemType :NewSQL, :DistributedDatabase ;
    :programmingLanguage "Go, Rust" ;
    :license "Apache-2.0" ;
    :github "https://github.com/pingcap/tidb" ;
    :created 2015 ;
    :isActive true ;
    :implements :Raft, :Percolator ;
    :uses sys:TiKV, sys:PD, :Spanner ;
    :relatedTo sys:CockroachDB, sys:Spanner, sys:YugabyteDB ;
    :difficulty "高级"@zh .

sys:TiKV rdf:type :System, owl:NamedIndividual ;
    rdfs:label "TiKV"@en ;
    :name "TiKV"@en ;
    :nameEn "TiKV"@en ;
    :definition "分布式事务键值存储，受Google Spanner启发"@zh ;
    :systemType :KeyValueStore, :TransactionalStore ;
    :programmingLanguage "Rust" ;
    :license "Apache-2.0" ;
    :github "https://github.com/tikv/tikv" ;
    :created 2016 ;
    :isActive true ;
    :implements :Raft, :MultiRaft ;
    :uses :RocksDB, :gRPC ;
    :usedBy sys:TiDB ;
    :relatedTo sys:etcd, sys:CockroachDB ;
    :difficulty "高级"@zh .

sys:CockroachDB rdf:type :System, owl:NamedIndividual ;
    rdfs:label "CockroachDB"@en ;
    :name "CockroachDB"@en ;
    :nameEn "CockroachDB"@en ;
    :definition "开源的分布式SQL数据库，提供ACID事务和一致性"@zh ;
    :systemType :NewSQL, :DistributedDatabase ;
    :programmingLanguage "Go" ;
    :license "BSL/Apache-2.0" ;
    :github "https://github.com/cockroachdb/cockroach" ;
    :created 2014 ;
    :isActive true ;
    :implements :MultiRaft, :SerializableIsolation ;
    :uses :RocksDB ;
    :relatedTo sys:TiDB, sys:Spanner, sys:YugabyteDB ;
    :difficulty "高级"@zh .

