# ============================================
# 其他重要概念 (Other Key Concepts)
# ============================================

:VectorClock rdf:type :Algorithm, owl:NamedIndividual ;
    rdfs:label "向量时钟"@zh, "Vector Clock"@en ;
    :name "向量时钟"@zh ;
    :nameEn "Vector Clock"@en ;
    :definition "用于在分布式系统中捕获因果关系的时间戳机制"@zh ;
    :category :Algorithm ;
    :proposedBy person:LeslieLamport ;
    :hasYear 1988 ;
    :implementedBy sys:DynamoDB, sys:Cassandra, sys:Riak ;
    :difficulty "中级"@zh .

:LamportTimestamp rdf:type :Algorithm, owl:NamedIndividual ;
    rdfs:label "Lamport时间戳"@zh, "Lamport Timestamp"@en ;
    :name "Lamport时间戳"@zh ;
    :nameEn "Lamport Timestamp"@en ;
    :definition "分布式系统中的逻辑时钟，用于确定事件的偏序关系"@zh ;
    :category :Algorithm ;
    :proposedBy person:LeslieLamport ;
    :hasYear 1978 ;
    :relatedTo :VectorClock, :HappensBefore ;
    :difficulty "中级"@zh .

:TwoPhaseCommit rdf:type :Protocol, owl:NamedIndividual ;
    rdfs:label "两阶段提交"@zh, "Two-Phase Commit"@en ;
    :name "两阶段提交"@zh ;
    :nameEn "Two-Phase Commit"@en ;
    :definition "分布式事务协议，通过协调者和参与者的两阶段交互实现原子提交"@zh ;
    :category :Protocol ;
    :hasPart :VotingPhase, :CommitPhase ;
    :hasYear 1981 ;
    :extends :ThreePhaseCommit ;
    :difficulty "中级"@zh .

:ThreePhaseCommit rdf:type :Protocol, owl:NamedIndividual ;
    rdfs:label "三阶段提交"@zh, "Three-Phase Commit"@en ;
    :name "三阶段提交"@zh ;
    :nameEn "Three-Phase Commit"@en ;
    :definition "改进的两阶段提交，增加预提交阶段以处理协调者故障"@zh ;
    :category :Protocol ;
    :hasPart :CanCommitPhase, :PreCommitPhase, :DoCommitPhase ;
    :hasYear 1981 ;
    :difficulty "中级"@zh .

:SagaPattern rdf:type :Pattern, owl:NamedIndividual ;
    rdfs:label "Saga模式"@zh, "Saga Pattern"@en ;
    :name "Saga模式"@zh ;
    :nameEn "Saga Pattern"@en ;
    :definition "长事务拆分模式，通过补偿操作保证最终一致性"@zh ;
    :category :Pattern ;
    :hasPart :ChoreographySaga, :OrchestrationSaga ;
    :hasYear 1987 ;
    :uses :CompensatingTransaction ;
    :difficulty "中级"@zh .

:TCC rdf:type :Pattern, owl:NamedIndividual ;
    rdfs:label "TCC模式"@zh, "Try-Confirm-Cancel"@en ;
    :name "TCC模式"@zh ;
    :nameEn "Try-Confirm-Cancel"@en ;
    :definition "柔性事务模式，通过预留、确认、取消三阶段实现最终一致性"@zh ;
    :category :Pattern ;
    :hasPart :TryPhase, :ConfirmPhase, :CancelPhase ;
    :difficulty "中级"@zh .

:MVCC rdf:type :Concept, owl:NamedIndividual ;
    rdfs:label "多版本并发控制"@zh, "Multi-Version Concurrency Control"@en ;
    :name "多版本并发控制"@zh ;
    :nameEn "MVCC"@en ;
    :definition "通过维护数据的多个版本来实现并发控制，避免读写冲突"@zh ;
    :category :Theory ;
    :hasYear 1981 ;
    :implementedBy sys:PostgreSQL, sys:MySQL, sys:Spanner, sys:TiDB ;
    :difficulty "高级"@zh .

:ConsistentHashing rdf:type :Algorithm, owl:NamedIndividual ;
    rdfs:label "一致性哈希"@zh, "Consistent Hashing"@en ;
    :name "一致性哈希"@zh ;
    :nameEn "Consistent Hashing"@en ;
    :definition "分布式哈希表的一种技术，当节点增减时最小化键的重新映射"@zh ;
    :category :Algorithm ;
    :hasYear 1997 ;
    :implementedBy sys:DynamoDB, sys:Cassandra, sys:Riak ;
    :difficulty "中级"@zh .

:Quorum rdf:type :Concept, owl:NamedIndividual ;
    rdfs:label "法定人数"@zh, "Quorum"@en ;
    :name "法定人数"@zh ;
    :nameEn "Quorum"@en ;
    :definition "分布式系统中进行决策所需的最小同意票数"@zh ;
    :category :Theory ;
    :hasPart :ReadQuorum, :WriteQuorum ;
    :usedBy :DynamoDB, :Cassandra, :ZooKeeper ;
    :difficulty "中级"@zh .

:Availability rdf:type :Concept, owl:NamedIndividual ;
    rdfs:label "可用性"@zh, "Availability"@en ;
    :name "可用性"@zh ;
    :nameEn "Availability"@en ;
    :definition "系统在规定时间内正常响应请求的能力"@zh ;
    :category :Theory ;
    :partOf :CAPTheorem ;
    :measuredBy :Uptime, :SLA ;
    :difficulty "初级"@zh .

:PartitionTolerance rdf:type :Concept, owl:NamedIndividual ;
    rdfs:label "分区容忍性"@zh, "Partition Tolerance"@en ;
    :name "分区容忍性"@zh ;
    :nameEn "Partition Tolerance"@en ;
    :definition "系统在出现网络分区时仍能继续运行的能力"@zh ;
    :category :Theory ;
    :partOf :CAPTheorem ;
    :difficulty "初级"@zh .

:Replication rdf:type :Concept, owl:NamedIndividual ;
    rdfs:label "复制"@zh, "Replication"@en ;
    :name "复制"@zh ;
    :nameEn "Replication"@en ;
    :definition "在多个节点上维护数据副本以提高可用性和性能"@zh ;
    :category :Theory ;
    :hasPart :MasterSlaveReplication, :MultiMasterReplication, :LeaderlessReplication ;
    :difficulty "中级"@zh .

:Sharding rdf:type :Concept, owl:NamedIndividual ;
    rdfs:label "分片"@zh, "Sharding"@en ;
    :name "分片"@zh ;
    :nameEn "Sharding"@en ;
    :definition "将数据水平分割到多个节点以扩展存储和计算能力"@zh ;
    :category :Theory ;
    :hasPart :RangeSharding, :HashSharding ;
    :uses :ConsistentHashing ;
    :difficulty "中级"@zh .

:CircuitBreaker rdf:type :Pattern, owl:NamedIndividual ;
    rdfs:label "熔断器模式"@zh, "Circuit Breaker Pattern"@en ;
    :name "熔断器模式"@zh ;
    :nameEn "Circuit Breaker Pattern"@en ;
    :definition "防止级联故障的模式，当错误率超过阈值时自动断开连接"@zh ;
    :category :Pattern ;
    :hasPart :ClosedState, :OpenState, :HalfOpenState ;
    :usedBy :Netflix, :Istio ;
    :difficulty "初级"@zh .

:RateLimiting rdf:type :Pattern, owl:NamedIndividual ;
    rdfs:label "限流模式"@zh, "Rate Limiting"@en ;
    :name "限流模式"@zh ;
    :nameEn "Rate Limiting"@en ;
    :definition "控制请求速率以保护系统免受过载"@zh ;
    :category :Pattern ;
    :hasPart :TokenBucket, :LeakyBucket, :FixedWindow, :SlidingWindow ;
    :difficulty "初级"@zh .

:Backpressure rdf:type :Pattern, owl:NamedIndividual ;
    rdfs:label "背压"@zh, "Backpressure"@en ;
    :name "背压"@zh ;
    :nameEn "Backpressure"@en ;
    :definition "当消费者处理速度跟不上生产者时，向上游传递压力信号"@zh ;
    :category :Pattern ;
    :implementedBy sys:ReactiveStreams, sys:Flink ;
    :difficulty "中级"@zh .

:CRDT rdf:type :Concept, owl:NamedIndividual ;
    rdfs:label "无冲突复制数据类型"@zh, "Conflict-free Replicated Data Type"@en ;
    :name "无冲突复制数据类型"@zh ;
    :nameEn "CRDT"@en ;
    :definition "保证在网络分区下也能实现最终一致性的数据结构"@zh ;
    :category :Theory ;
    :hasPart :StateBasedCRDT, :OperationBasedCRDT ;
    :hasYear 2011 ;
    :implementedBy sys:Riak, sys:Redis, sys:AntidoteDB ;
    :difficulty "高级"@zh .

:ServiceDiscovery rdf:type :Concept, owl:NamedIndividual ;
    rdfs:label "服务发现"@zh, "Service Discovery"@en ;
    :name "服务发现"@zh ;
    :nameEn "Service Discovery"@en ;
    :definition "在动态环境中自动定位和连接服务实例的机制"@zh ;
    :category :Pattern ;
    :implementedBy sys:Consul, sys:etcd, sys:Eureka, sys:Nacos ;
    :difficulty "中级"@zh .

:LoadBalancing rdf:type :Concept, owl:NamedIndividual ;
    rdfs:label "负载均衡"@zh, "Load Balancing"@en ;
    :name "负载均衡"@zh ;
    :nameEn "Load Balancing"@en ;
    :definition "将请求分配到多个服务器以优化资源使用和响应时间"@zh ;
    :category :Theory ;
    :hasPart :RoundRobin, :LeastConnections, :ConsistentHashing, :Random ;
    :implementedBy sys:Nginx, sys:HAProxy, sys:Envoy ;
    :difficulty "初级"@zh .

:Observability rdf:type :Concept, owl:NamedIndividual ;
    rdfs:label "可观测性"@zh, "Observability"@en ;
    :name "可观测性"@zh ;
    :nameEn "Observability"@en ;
    :definition "通过外部输出推断系统内部状态的能力，包括日志、指标和追踪"@zh ;
    :category :Theory ;
    :hasPart :Logging, :Metrics, :Tracing ;
    :implementedBy sys:Prometheus, sys:Jaeger, sys:Grafana, sys:ELK ;
    :difficulty "中级"@zh .

:ServiceMesh rdf:type :Concept, owl:NamedIndividual ;
    rdfs:label "服务网格"@zh, "Service Mesh"@en ;
    :name "服务网格"@zh ;
    :nameEn "Service Mesh"@en ;
    :definition "处理服务间通信的基础设施层，透明地提供流量管理、安全和可观测性"@zh ;
    :category :Architecture ;
    :hasPart :DataPlane, :ControlPlane ;
    :implementedBy sys:Istio, sys:Linkerd, sys:Consul ;
    :difficulty "高级"@zh .

:Serverless rdf:type :Concept, owl:NamedIndividual ;
    rdfs:label "无服务器"@zh, "Serverless"@en ;
    :name "无服务器"@zh ;
    :nameEn "Serverless"@en ;
    :definition "云计算执行模型，云提供商动态管理服务器资源分配"@zh ;
    :category :Architecture ;
    :hasPart :FaaS, :BaaS ;
    :implementedBy sys:AWSLambda, sys:AzureFunctions, sys:Knative ;
    :difficulty "中级"@zh .

:ChaosEngineering rdf:type :Concept, owl:NamedIndividual ;
    rdfs:label "混沌工程"@zh, "Chaos Engineering"@en ;
    :name "混沌工程"@zh ;
    :nameEn "Chaos Engineering"@en ;
    :definition "通过在生产环境进行实验来建立对系统承受故障能力的信心"@zh ;
    :category :Theory ;
    :hasPart :ChaosMonkey, :LatencyInjection, :FailureInjection ;
    :implementedBy sys:ChaosMonkey, sys:Litmus, sys:ChaosMesh ;
    :difficulty "高级"@zh .

:ChandyLamportSnapshot rdf:type :Algorithm, owl:NamedIndividual ;
    rdfs:label "Chandy-Lamport快照算法"@zh, "Chandy-Lamport Snapshot"@en ;
    :name "Chandy-Lamport快照算法"@zh ;
    :nameEn "Chandy-Lamport Snapshot Algorithm"@en ;
    :definition "分布式系统中捕获全局一致状态的经典算法"@zh ;
    :category :Algorithm ;
    :proposedBy person:KManChandy, person:LeslieLamport ;
    :hasYear 1985 ;
    :implementedBy sys:Flink, sys:ApacheSamza ;
    :difficulty "高级"@zh .

:HotStuff rdf:type :Algorithm, owl:NamedIndividual ;
    rdfs:label "HotStuff算法"@zh, "HotStuff"@en ;
    :name "HotStuff算法"@zh ;
    :nameEn "HotStuff Consensus Protocol"@en ;
    :definition "基于BFT的共识算法，具有线性通信复杂度和响应性"@zh ;
    :category :Algorithm ;
    :isA :BFTAlgorithm ;
    :hasYear 2018 ;
    :implementedBy sys:Diem, sys:Celo ;
    :difficulty "高级"@zh .

:Tendermint rdf:type :Algorithm, owl:NamedIndividual ;
    rdfs:label "Tendermint共识"@zh, "Tendermint"@en ;
    :name "Tendermint共识"@zh ;
    :nameEn "Tendermint Consensus"@en ;
    :definition "基于BFT的PoS共识算法，用于区块链网络"@zh ;
    :category :Algorithm ;
    :isA :BFTAlgorithm, :PoS ;
    :hasYear 2014 ;
    :implementedBy sys:Cosmos ;
    :difficulty "高级"@zh .

:PoW rdf:type :Algorithm, owl:NamedIndividual ;
    rdfs:label "工作量证明"@zh, "Proof of Work"@en ;
    :name "工作量证明"@zh ;
    :nameEn "Proof of Work"@en ;
    :definition "通过计算难题证明工作量的共识机制"@zh ;
    :category :Algorithm ;
    :hasYear 1993 ;
    :implementedBy sys:Bitcoin, sys:Ethereum1 ;
    :difficulty "中级"@zh .

:PoS rdf:type :Algorithm, owl:NamedIndividual ;
    rdfs:label "权益证明"@zh, "Proof of Stake"@en ;
    :name "权益证明"@zh ;
    :nameEn "Proof of Stake"@en ;
    :definition "基于持币量和时间的共识机制，替代PoW"@zh ;
    :category :Algorithm ;
    :hasYear 2012 ;
    :implementedBy sys:Ethereum2, sys:Cosmos, sys:Cardano ;
    :difficulty "中级"@zh .

:Blockchain rdf:type :Concept, owl:NamedIndividual ;
    rdfs:label "区块链"@zh, "Blockchain"@en ;
    :name "区块链"@zh ;
    :nameEn "Blockchain"@en ;
    :definition "分布式账本技术，通过密码学链接的数据块链"@zh ;
    :category :Architecture ;
    :hasPart :Block, :Transaction, :Consensus, :SmartContract ;
    :implements :PoW, :PoS, :PBFT ;
    :difficulty "中级"@zh .

:SmartContract rdf:type :Concept, owl:NamedIndividual ;
    rdfs:label "智能合约"@zh, "Smart Contract"@en ;
    :name "智能合约"@zh ;
    :nameEn "Smart Contract"@en ;
    :definition "在区块链上自动执行的程序代码"@zh ;
    :category :Pattern ;
    :hasYear 1994 ;
    :implementedBy sys:Ethereum, sys:EOS, sys:HyperledgerFabric ;
    :difficulty "中级"@zh .

# ============================================
# 补充概念与组件
# ============================================

:AvailabilityZone rdf:type :Concept, owl:NamedIndividual ;
    rdfs:label "可用区"@zh, "Availability Zone"@en ;
    :name "可用区"@zh ;
    :nameEn "Availability Zone"@en ;
    :definition "云数据中心中物理隔离的区域，用于高可用性设计"@zh ;
    :category :Architecture ;
    :difficulty "初级"@zh .

:Region rdf:type :Concept, owl:NamedIndividual ;
    rdfs:label "区域"@zh, "Region"@en ;
    :name "区域"@zh ;
    :nameEn "Region"@en ;
    :definition "地理上独立的数据中心位置"@zh ;
    :category :Architecture ;
    :hasPart :AvailabilityZone ;
    :difficulty "初级"@zh .

:EdgeComputing rdf:type :Concept, owl:NamedIndividual ;
    rdfs:label "边缘计算"@zh, "Edge Computing"@en ;
    :name "边缘计算"@zh ;
    :nameEn "Edge Computing"@en ;
    :definition "在网络边缘靠近数据源处理数据的计算范式"@zh ;
    :category :Architecture ;
    :relatedTo :FogComputing, :CDN ;
    :difficulty "中级"@zh .

:FogComputing rdf:type :Concept, owl:NamedIndividual ;
    rdfs:label "雾计算"@zh, "Fog Computing"@en ;
    :name "雾计算"@zh ;
    :nameEn "Fog Computing"@en ;
    :definition "介于云计算和边缘计算之间的中间层计算架构"@zh ;
    :category :Architecture ;
    :relatedTo :EdgeComputing ;
    :difficulty "中级"@zh .

:CDN rdf:type :Concept, owl:NamedIndividual ;
    rdfs:label "内容分发网络"@zh, "Content Delivery Network"@en ;
    :name "内容分发网络"@zh ;
    :nameEn "Content Delivery Network"@en ;
    :definition "地理分布的服务器网络，用于加速内容传输"@zh ;
    :category :Architecture ;
    :difficulty "初级"@zh .

:Microservices rdf:type :Concept, owl:NamedIndividual ;
    rdfs:label "微服务架构"@zh, "Microservices Architecture"@en ;
    :name "微服务架构"@zh ;
    :nameEn "Microservices Architecture"@en ;
    :definition "将应用拆分为小型、独立部署服务的架构风格"@zh ;
    :category :Architecture ;
    :hasPart :ServiceDiscovery, :API gateway, :CircuitBreaker ;
    :relatedTo :ServiceMesh, :Serverless ;
    :difficulty "中级"@zh .

:APIGateway rdf:type :Concept, owl:NamedIndividual ;
    rdfs:label "API网关"@zh, "API Gateway"@en ;
    :name "API网关"@zh ;
    :nameEn "API Gateway"@en ;
    :definition "管理、路由和保护API请求的服务入口"@zh ;
    :category :Architecture ;
    :hasPart :Routing, :Authentication, :RateLimiting ;
    :implementedBy sys:Kong, sys:Envoy, sys:Nginx, sys:Zuul ;
    :difficulty "中级"@zh .

:ZeroTrust rdf:type :Concept, owl:NamedIndividual ;
    rdfs:label "零信任安全"@zh, "Zero Trust Security"@en ;
    :name "零信任安全"@zh ;
    :nameEn "Zero Trust Security"@en ;
    :definition "不信任任何内外部网络的安全模型，始终验证身份和设备"@zh ;
    :category :Theory ;
    :hasPart :IdentityVerification, :DeviceTrust, :LeastPrivilege ;
    :difficulty "高级"@zh .

:MTLS rdf:type :Protocol, owl:NamedIndividual ;
    rdfs:label "双向TLS"@zh, "Mutual TLS"@en ;
    :name "双向TLS"@zh ;
    :nameEn "Mutual TLS"@en ;
    :definition "客户端和服务器相互验证的TLS协议"@zh ;
    :category :Protocol ;
    :usedBy sys:Istio, sys:Linkerd ;
    :difficulty "中级"@zh .

:OAuth2 rdf:type :Protocol, owl:NamedIndividual ;
    rdfs:label "OAuth 2.0"@en ;
    :name "OAuth 2.0"@en ;
    :nameEn "OAuth 2.0"@en ;
    :definition "授权框架，允许第三方应用获得有限的资源访问权限"@zh ;
    :category :Protocol ;
    :hasYear 2012 ;
    :hasPart :AuthorizationCode, :Implicit, :Password, :ClientCredentials ;
    :difficulty "中级"@zh .

:JWT rdf:type :Concept, owl:NamedIndividual ;
    rdfs:label "JSON Web Token"@en ;
    :name "JWT"@en ;
    :nameEn "JSON Web Token"@en ;
    :definition "用于安全传输信息的紧凑、自包含方式"@zh ;
    :category :Protocol ;
    :hasYear 2015 ;
    :difficulty "初级"@zh .

:ACID rdf:type :Concept, owl:NamedIndividual ;
    rdfs:label "ACID属性"@zh, "ACID Properties"@en ;
    :name "ACID"@en ;
    :nameEn "Atomicity, Consistency, Isolation, Durability"@en ;
    :definition "数据库事务的四个基本属性：原子性、一致性、隔离性、持久性"@zh ;
    :category :Theory ;
    :hasPart :Atomicity, :Isolation, :Durability ;
    :difficulty "初级"@zh .

:BASE rdf:type :Concept, owl:NamedIndividual ;
    rdfs:label "BASE模型"@zh, "BASE Model"@en ;
    :name "BASE"@en ;
    :nameEn "Basically Available, Soft state, Eventually consistent"@en ;
    :definition "NoSQL数据库的可用性优先模型，与ACID相对"@zh ;
    :category :Theory ;
    :hasYear 2008 ;
    :relatedTo :ACID, :EventualConsistency ;
    :difficulty "初级"@zh .

:DistributedTransaction rdf:type :Concept, owl:NamedIndividual ;
    rdfs:label "分布式事务"@zh, "Distributed Transaction"@en ;
    :name "分布式事务"@zh ;
    :nameEn "Distributed Transaction"@en ;
    :definition "跨多个数据源或服务的事务，需要协调保证原子性"@zh ;
    :category :Theory ;
    :uses :TwoPhaseCommit, :ThreePhaseCommit, :SagaPattern, :TCC ;
    :difficulty "高级"@zh .

:DistributedLock rdf:type :Concept, owl:NamedIndividual ;
    rdfs:label "分布式锁"@zh, "Distributed Lock"@en ;
    :name "分布式锁"@zh ;
    :nameEn "Distributed Lock"@en ;
    :definition "在分布式系统中协调多个进程访问共享资源的机制"@zh ;
    :category :Pattern ;
    :implementedBy sys:Redis, sys:ZooKeeper, sys:etcd ;
    :difficulty "中级"@zh .

:Idempotency rdf:type :Concept, owl:NamedIndividual ;
    rdfs:label "幂等性"@zh, "Idempotency"@en ;
    :name "幂等性"@zh ;
    :nameEn "Idempotency"@en ;
    :definition "操作执行一次和执行多次产生相同结果的性质"@zh ;
    :category :Theory ;
    :difficulty "中级"@zh .

:ExactlyOnceSemantics rdf:type :Concept, owl:NamedIndividual ;
    rdfs:label "恰好一次语义"@zh, "Exactly-Once Semantics"@en ;
    :name "恰好一次语义"@zh ;
    :nameEn "Exactly-Once Semantics"@en ;
    :definition "保证消息只被处理一次的语义，通常通过幂等性和事务实现"@zh ;
    :category :Theory ;
    :implementedBy sys:Kafka, sys:Flink ;
    :relatedTo :Idempotency ;
    :difficulty "高级"@zh .

:AtLeastOnce rdf:type :Concept, owl:NamedIndividual ;
    rdfs:label "至少一次"@zh, "At-Least-Once"@en ;
    :name "至少一次"@zh ;
    :nameEn "At-Least-Once"@en ;
    :definition "保证消息至少被处理一次，可能重复"@zh ;
    :category :Theory ;
    :difficulty "初级"@zh .

:AtMostOnce rdf:type :Concept, owl:NamedIndividual ;
    rdfs:label "至多一次"@zh, "At-Most-Once"@en ;
    :name "至多一次"@zh ;
    :nameEn "At-Most-Once"@en ;
    :definition "保证消息最多被处理一次，可能丢失"@zh ;
    :category :Theory ;
    :difficulty "初级"@zh .

:WAL rdf:type :Concept, owl:NamedIndividual ;
    rdfs:label "预写日志"@zh, "Write-Ahead Log"@en ;
    :name "预写日志"@zh ;
    :nameEn "Write-Ahead Log"@en ;
    :definition "在修改数据前先写入日志，保证持久性和恢复能力"@zh ;
    :category :Theory ;
    :implementedBy sys:PostgreSQL, sys:MySQL, sys:Cassandra ;
    :difficulty "中级"@zh .

:LSMTree rdf:type :Concept, owl:NamedIndividual ;
    rdfs:label "LSM树"@zh, "Log-Structured Merge Tree"@en ;
    :name "LSM树"@zh ;
    :nameEn "Log-Structured Merge Tree"@en ;
    :definition "通过批量合并优化写性能的磁盘数据结构"@zh ;
    :category :Theory ;
    :hasYear 1996 ;
    :implementedBy sys:RocksDB, sys:LevelDB, sys:Cassandra, sys:HBase ;
    :difficulty "高级"@zh .

:BTree rdf:type :Concept, owl:NamedIndividual ;
    rdfs:label "B树"@zh, "B-Tree"@en ;
    :name "B树"@zh ;
    :nameEn "B-Tree"@en ;
    :definition "平衡的多路搜索树，广泛用于数据库索引"@zh ;
    :category :Algorithm ;
    :hasYear 1972 ;
    :implementedBy sys:PostgreSQL, sys:MySQL, sys:MongoDB ;
    :difficulty "中级"@zh .

:Gossip rdf:type :Protocol, owl:NamedIndividual ;
    rdfs:label "Gossip协议"@zh, "Gossip Protocol"@en ;
    :name "Gossip协议"@zh ;
    :nameEn "Gossip Protocol"@en ;
    :definition "基于随机传播的 epidemic 算法，用于信息传播和故障检测"@zh ;
    :category :Protocol ;
    :hasPart :AntiEntropy, :RumorMongering ;
    :implementedBy sys:Cassandra, sys:Consul, sys:Redis ;
    :difficulty "中级"@zh .

:HeartBeat rdf:type :Protocol, owl:NamedIndividual ;
    rdfs:label "心跳机制"@zh, "Heartbeat"@en ;
    :name "心跳机制"@zh ;
    :nameEn "Heartbeat"@en ;
    :definition "通过定期消息检测节点存活状态的机制"@zh ;
    :category :Protocol ;
    :difficulty "初级"@zh .

:Timeout rdf:type :Concept, owl:NamedIndividual ;
    rdfs:label "超时"@zh, "Timeout"@en ;
    :name "超时"@zh ;
    :nameEn "Timeout"@en ;
    :definition "在指定时间内未收到响应则采取预设动作的机制"@zh ;
    :category :Theory ;
    :difficulty "初级"@zh .

:Retry rdf:type :Pattern, owl:NamedIndividual ;
    rdfs:label "重试模式"@zh, "Retry Pattern"@en ;
    :name "重试模式"@zh ;
    :nameEn "Retry Pattern"@en ;
    :definition "临时失败后自动重试操作的容错模式"@zh ;
    :category :Pattern ;
    :hasPart :ExponentialBackoff, :Jitter ;
    :difficulty "初级"@zh .

:ExponentialBackoff rdf:type :Concept, owl:NamedIndividual ;
    rdfs:label "指数退避"@zh, "Exponential Backoff"@en ;
    :name "指数退避"@zh ;
    :nameEn "Exponential Backoff"@en ;
    :definition "每次重试后指数级增加等待时间的策略"@zh ;
    :category :Algorithm ;
    :usedBy :Retry ;
    :difficulty "初级"@zh .

:GracefulShutdown rdf:type :Pattern, owl:NamedIndividual ;
    rdfs:label "优雅关闭"@zh, "Graceful Shutdown"@en ;
    :name "优雅关闭"@zh ;
    :nameEn "Graceful Shutdown"@en ;
    :definition "在停止服务前完成进行中的请求和清理资源"@zh ;
    :category :Pattern ;
    :difficulty "中级"@zh .

:HealthCheck rdf:type :Pattern, owl:NamedIndividual ;
    rdfs:label "健康检查"@zh, "Health Check"@en ;
    :name "健康检查"@zh ;
    :nameEn "Health Check"@en ;
    :definition "定期检查系统组件健康状态的机制"@zh ;
    :category :Pattern ;
    :hasPart :LivenessProbe, :ReadinessProbe ;
    :difficulty "初级"@zh .

:Bulkhead rdf:type :Pattern, owl:NamedIndividual ;
    rdfs:label "舱壁隔离"@zh, "Bulkhead Pattern"@en ;
    :name "舱壁隔离"@zh ;
    :nameEn "Bulkhead Pattern"@en ;
    :definition "将资源隔离到池中，防止一个组件故障影响其他组件"@zh ;
    :category :Pattern ;
    :difficulty "中级"@zh .

:StranglerFig rdf:type :Pattern, owl:NamedIndividual ;
    rdfs:label "绞杀者模式"@zh, "Strangler Fig Pattern"@en ;
    :name "绞杀者模式"@zh ;
    :nameEn "Strangler Fig Pattern"@en ;
    :definition "逐步用新系统替换旧系统的渐进式迁移模式"@zh ;
    :category :Pattern ;
    :difficulty "中级"@zh .

:Sidecar rdf:type :Pattern, owl:NamedIndividual ;
    rdfs:label "边车模式"@zh, "Sidecar Pattern"@en ;
    :name "边车模式"@zh ;
    :nameEn "Sidecar Pattern"@en ;
    :definition "将辅助功能部署为与主应用同生命周期的独立容器"@zh ;
    :category :Pattern ;
    :usedBy :ServiceMesh ;
    :difficulty "中级"@zh .

:Ambassador rdf:type :Pattern, owl:NamedIndividual ;
    rdfs:label "大使模式"@zh, "Ambassador Pattern"@en ;
    :name "大使模式"@zh ;
    :nameEn "Ambassador Pattern"@en ;
    :definition "通过代理容器处理客户端与外部服务的连接"@zh ;
    :category :Pattern ;
    :difficulty "中级"@zh .

:Adapter rdf:type :Pattern, owl:NamedIndividual ;
    rdfs:label "适配器模式"@zh, "Adapter Pattern"@en ;
    :name "适配器模式"@zh ;
    :nameEn "Adapter Pattern"@en ;
    :definition "将不兼容接口转换为可兼容接口的结构型模式"@zh ;
    :category :Pattern ;
    :difficulty "初级"@zh .

:EventSourcing rdf:type :Pattern, owl:NamedIndividual ;
    rdfs:label "事件溯源"@zh, "Event Sourcing"@en ;
    :name "事件溯源"@zh ;
    :nameEn "Event Sourcing"@en ;
    :definition "通过存储事件序列来重建系统状态的模式"@zh ;
    :category :Pattern ;
    :hasPart :EventStore, :CQRS ;
    :difficulty "高级"@zh .

:CQRS rdf:type :Pattern, owl:NamedIndividual ;
    rdfs:label "命令查询职责分离"@zh, "CQRS"@en ;
    :name "CQRS"@en ;
    :nameEn "Command Query Responsibility Segregation"@en ;
    :definition "将读取和写入操作分离到不同模型的架构模式"@zh ;
    :category :Pattern ;
    :relatedTo :EventSourcing ;
    :difficulty "高级"@zh .

:MaterializedView rdf:type :Pattern, owl:NamedIndividual ;
    rdfs:label "物化视图"@zh, "Materialized View"@en ;
    :name "物化视图"@zh ;
    :nameEn "Materialized View"@en ;
    :definition "预先计算并存储的查询结果，用于优化读取性能"@zh ;
    :category :Pattern ;
    :difficulty "中级"@zh .

:OutboxPattern rdf:type :Pattern, owl:NamedIndividual ;
    rdfs:label "发件箱模式"@zh, "Outbox Pattern"@en ;
    :name "发件箱模式"@zh ;
    :nameEn "Outbox Pattern"@en ;
    :definition "保证数据库事务和消息发送原子性的模式"@zh ;
    :category :Pattern ;
    :difficulty "高级"@zh .

:TransactionOutbox rdf:type :Pattern, owl:NamedIndividual ;
    rdfs:label "事务发件箱"@zh, "Transaction Outbox"@en ;
    :name "事务发件箱"@zh ;
    :nameEn "Transaction Outbox"@en ;
    :definition "与Outbox模式相同，确保消息可靠发送"@zh ;
    :category :Pattern ;
    :sameAs :OutboxPattern ;
    :difficulty "高级"@zh .
